{
  "manifest_version": 3,
  "name": "WebTime",
  "version": "0.1.2",
  "description": "Track time on the focused tab of the active window and enforce per-site limits.",
  "icons": {
    "16": "icon/icon-16.png",
    "32": "icon/icon-32.png",
    "48": "icon/icon-48.png",
    "128": "icon/icon-128.png"
  },
  "action": {
    "default_icon": {
      "19": "icon/icon-19.png",
      "38": "icon/icon-38.png"
    },
    "default_popup": "html/popup.html",
    "default_title": "WebTime"
  },
  "options_ui": {
    "page": "html/options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "permissions": [
    "alarms",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "idle",
    "storage",
    "tabs"
  ]
}
