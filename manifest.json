{
  "manifest_version": 3,
  "name": "WebTime",
  "version": "0.1.0",
  "description": "A minimal Manifest V3 Chrome extension starting point.",
  "icons": {
    "16": "icon/icon-16.png",
    "32": "icon/icon-32.png",
    "48": "icon/icon-48.png",
    "128": "icon/icon-128.png"
  },
  "action": {
    "default_icon": {
      "19": "icon/icon-19.png",
      "38": "icon/icon-38.png"
    },
    "default_popup": "html/popup.html",
    "default_title": "WebTime"
  }
}
